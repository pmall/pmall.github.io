---
import '../styles/global.css';
import LocaleToggle from '../components/LocaleToggle.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  locale: 'en' | 'fr';
}
const { locale } = Astro.props;
---
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>Pierre Mallinjoud</title>
    <meta name="description" content="Pierre Mallinjoud portfolio" />
  </head>
  <body>
    <main class="min-h-screen bg-white text-gray-800">
      <div class="container mx-auto px-4 py-8 max-w-4xl">
        <LocaleToggle locale={locale} />
        <div class="mb-8">
          <Header locale={locale} />
        </div>
        <slot />
        <div class="mt-16 border-t border-gray-100">
          <Footer locale={locale} />
        </div>
      </div>
    </main>
  </body>
</html>
