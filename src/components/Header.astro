---
import { Mail, FileText, Github, Linkedin } from 'lucide-astro';
import { ui } from '../i18n/ui';

interface Props {
  locale: 'en' | 'fr';
}
const { locale } = Astro.props;
const t = ui[locale];
---
<header class="flex flex-col md:flex-row items-center md:items-start gap-6">
  <div class="w-24 h-24 rounded-full overflow-hidden flex-shrink-0 border-2 border-blue-100">
    <img src="/profile.jpeg" alt="Pierre Mallinjoud" class="w-full h-full object-cover" />
  </div>

  <div class="text-center md:text-left">
    <h1 class="text-2xl font-bold text-gray-900">Pierre Mallinjoud</h1>
    <p class="text-blue-600 mb-2">{t.subtitle}</p>
    <p class="text-gray-600 mb-4 whitespace-pre-line">{t.description}</p>
    <div class="mb-4">
      <a
        href={t.resumeFilePath}
        class="inline-flex items-center gap-2 text-sm bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors"
        download
      >
        <FileText class="h-4 w-4" />
        {t.downloadResume}
      </a>
    </div>
    <div class="flex flex-wrap justify-center md:justify-start gap-3">
      <a href="mailto:pierre.mallinjoud@gmail.com" class="flex items-center gap-1 text-sm text-gray-600 hover:text-blue-600">
        <Mail class="h-4 w-4" />
        <span>Email</span>
      </a>
      <a href="https://github.com/pmall" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-sm text-gray-600 hover:text-blue-600">
        <Github class="h-4 w-4" />
        <span>GitHub</span>
      </a>
      <a href="https://www.linkedin.com/in/pierre-mallinjoud-08346a83/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-sm text-gray-600 hover:text-blue-600">
        <Linkedin class="h-4 w-4" />
        <span>LinkedIn</span>
      </a>
    </div>
  </div>
</header>
