---
import { Globe } from 'lucide-astro';

interface Props {
  locale: 'en' | 'fr';
}
const { locale } = Astro.props;
const targetLocale = locale === 'en' ? 'fr' : 'en';
const text = locale === 'en' ? 'Français' : 'English';

const href = `/${targetLocale}`;
---

<div class="flex justify-end mb-6">
  <a
    href={href}
    class="inline-flex items-center gap-2 text-sm text-blue-600 border border-blue-200 rounded-md px-3 py-1 hover:bg-blue-50 transition-colors"
  >
    <Globe class="h-4 w-4" />
    {text}
  </a>
</div>
